#!/usr/bin/env bash
set -euo pipefail

usage() {
  printf 'Usage: %s [OUTPUT_DIR]\n' "${0##*/}"
}

if (($# > 1)); then
  usage >&2
  exit 2
fi

if (($# == 1)); then
  output_dir=$1
else
  output_dir="${XDG_CONFIG_HOME:-${HOME}/.config}/package-manifests"
fi

mkdir -p -- "${output_dir}"
declare -a temporary_files=()

cleanup() {
  if ((${#temporary_files[@]} > 0)); then
    rm -f -- "${temporary_files[@]}"
  fi
}
trap cleanup EXIT HUP INT TERM

write_manifest() {
  local name=$1
  shift
  local temporary
  temporary=$(mktemp "${output_dir}/.${name}.XXXXXX")
  temporary_files+=("${temporary}")

  if ! LC_ALL=C "$@" | LC_ALL=C sort -u >"${temporary}"; then
    printf 'Failed to generate %s\n' "${name}" >&2
    return 1
  fi

  chmod 0644 "${temporary}"
  mv -f -- "${temporary}" "${output_dir}/${name}"
}

npm_packages() {
  npm ls --global --depth=0 --json 2>/dev/null | jq -r '.dependencies // {} | keys[]'
}

cargo_packages() {
  cargo install --list | awk '/^[^[:space:]].* v[^ ]+:$/ { sub(/:$/, ""); print }'
}

uv_packages() {
  uv tool list | awk '/^[^[:space:]-].* v[^ ]+$/ { print }'
}

mason_packages() {
  find "${XDG_DATA_HOME:-${HOME}/.local/share}/nvim/mason/packages" -mindepth 1 -maxdepth 1 -type d -printf '%f\n'
}

write_manifest pacman-native.txt pacman -Qqen
write_manifest pacman-foreign.txt pacman -Qqem

command -v flatpak >/dev/null 2>&1 && write_manifest flatpak-apps.txt flatpak list --app --columns=application
command -v pipx >/dev/null 2>&1 && write_manifest pipx-tools.txt pipx list --short
command -v uv >/dev/null 2>&1 && write_manifest uv-tools.txt uv_packages
if command -v cargo >/dev/null 2>&1 && [[ -n $(cargo_packages) ]]; then
  write_manifest cargo-tools.txt cargo_packages
else
  rm -f -- "${output_dir}/cargo-tools.txt"
fi
if command -v npm >/dev/null 2>&1 && command -v jq >/dev/null 2>&1; then
  npm_path=$(command -v npm)
  if [[ ${npm_path} != *codex-desktop* && ${npm_path} != *codex-runtimes* ]]; then
    write_manifest npm-global.txt npm_packages
  fi
fi
if [[ -d "${XDG_DATA_HOME:-${HOME}/.local/share}/nvim/mason/packages" ]]; then
  write_manifest mason-tools.txt mason_packages
fi
if command -v code >/dev/null 2>&1; then
  write_manifest vscode-extensions.txt code --list-extensions
fi

printf 'Package manifests updated atomically in %s\n' "${output_dir}"
for manifest in "${output_dir}"/*.txt; do
  [[ -e "${manifest}" ]] || continue
  printf '  %-24s %5d entries\n' "${manifest##*/}" "$(wc -l <"${manifest}")"
done
