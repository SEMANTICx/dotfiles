{
  "vim_mode": true,
  "relative_line_numbers": true,
  "soft_wrap": "bounded",
  "autosave": "on_focus_change",
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    }
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark"
  },
  "terminal": {
    "dock": "right"
  },
  "auto_install_extensions": {
    "latex": true,
    "typst": true
  },
  "lsp": {
    "texlab": {
      "settings": {
        "texlab": {
          "build": {
            "forwardSearchAfter": false,
            "executable": "tectonic",
            "args": [
              "-X",
              "compile",
              "--synctex",
              "--keep-logs",
              "%f"
            ]
          }
        }
      }
    },
    "tinymist": {
      "settings": {
        "exportPdf": "onSave"
      }
    }
  }
}
