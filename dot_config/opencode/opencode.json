{
  "$schema": "https://opencode.ai/config.json",
  "share": "manual",
  "instructions": [
    "/home/amedus/.config/opencode/instructions/frontend-routing.md"
  ],
  "model": "openrouter/openai/gpt-5.6-sol",
  "agent": {
    "build": {
      "model": "openrouter/openai/gpt-5.6-sol",
      "reasoningEffort": "max"
    },
    "plan": {
      "model": "openrouter/anthropic/claude-fable-5",
      "reasoningEffort": "max"
    }
  },
  "permission": {
    "edit": "allow",
    "task": "allow",
    "websearch": "allow",
    "webfetch": "ask",
    "external_directory": "ask",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "rg *": "allow",
      "pytest*": "allow",
      "cargo test*": "allow",
      "go test*": "allow",
      "npm test*": "allow",
      "npm run test*": "allow",
      "pnpm test*": "allow",
      "pnpm run test*": "allow",
      "git commit*": "ask",
      "git push*": "ask",
      "rm -rf *": "deny",
      "sudo *": "deny"
    }
  }
}
